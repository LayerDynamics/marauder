{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "marauder",
  "version": "0.1.0",
  "identifier": "com.ryanoboyle.marauder",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "marauder",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["underWindowBackground"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "GPU-accelerated terminal emulator",
    "longDescription": "Marauder is a GPU-accelerated, fully extensible terminal emulator built with Rust, Deno, and Tauri. Features instanced wgpu rendering at 120fps, a rich extension system, and cross-platform support.",
    "copyright": "Copyright (c) 2026 Ryan O'Boyle",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
